<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Project bill management for government officials">
  <title>Project Bill | Dashboard</title>

  <!-- Preconnect -->
  <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="preconnect" href="https://cdnjs.cloudflare.com" crossorigin>
  
  <!-- Styles -->
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <link rel="stylesheet" href="/officials-bill.css">
</head>

<body>
  <div class="wrapper">
    <!-- Mobile Toggle -->
    <div class="mobile-toggle" id="sidebarToggle">
      <i class="fas fa-bars"></i>
    </div>
    
    <!-- Sidebar -->
    <nav class="sidebar" id="sidebar">
      <h2>
        <img src="/images/logo.png" class="logo" alt="Logo">
      </h2>
      <ul>
        <li><a href="/officials-dashboard"><i class="fas fa-home"></i> Home</a></li>
        <li><a href="/officials-project"><i class="fas fa-tasks"></i> Project</a></li>
        <li><a href="/officials-project-progress"><i class="fas fa-chart-line"></i> Project Progress</a></li>
        <li><a href="/officials-notification"><i class="fas fa-bell"></i> Notification</a></li>
        <li><a href="/officials-bill" class="active"><i class="fas fa-file-invoice-dollar"></i> Bill</a></li>
      </ul>
    </nav>

    <!-- Main Content -->
    <main class="main-content">
      <!-- Header -->
      <header class="top-header">
        <h1>Project Bill</h1>
        <div class="profile-menu">
          <i class="fas fa-user-circle profile-icon" aria-label="User menu"></i>
          <div class="dropdown-menu">
            <a href="/profile"><i class="fas fa-user"></i> Profile</a>
            <a href="/logout"><i class="fas fa-sign-out-alt"></i> Logout</a>
          </div>
        </div>
      </header>

      <div class="content">
        <div class="stat-section">
          <div class="section-header"><i class="fas fa-file-invoice-dollar"></i> Government Fund Allocation Bill</div>
          <div class="bill-container" id="billContent">
            <div class="bill-header">
              <p>Generated on: <%= project.billGeneratedAt %></p>
            </div>

            <div class="bill-details">
              <div class="bill-section">
                <h3>Project Information</h3>
                <div class="bill-item">
                  <div class="bill-item-label">Project Name:</div>
                  <div class="bill-item-value"><%= project.projectName %></div>
                </div>
                <div class="bill-item">
                  <div class="bill-item-label">Department:</div>
                  <div class="bill-item-value"><%= project.department %></div>
                </div>
                <div class="bill-item">
                  <div class="bill-item-label">Allocated Fund:</div>
                  <div class="bill-item-value">$<%= project.allocatedFund.toLocaleString() %></div>
                </div>
                <div class="bill-item">
                  <div class="bill-item-label">Start Date:</div>
                  <div class="bill-item-value"><%= project.startDate %></div>
                </div>
                <div class="bill-item">
                  <div class="bill-item-label">Deadline:</div>
                  <div class="bill-item-value"><%= project.projectDeadline %></div>
                </div>
              </div>

              <div class="bill-section">
                <h3>Approval Information</h3>
                <div class="bill-item">
                  <div class="bill-item-label">Requested By:</div>
                  <div class="bill-item-value"><%= project.requestedBy ? project.requestedBy.name : 'N/A' %></div>
                </div>
                <div class="bill-item">
                  <div class="bill-item-label">Approved By:</div>
                  <div class="bill-item-value"><%= project.actionBy ? project.actionBy.name : 'N/A' %></div>
                </div>
                <div class="bill-item">
                  <div class="bill-item-label">Approval Date:</div>
                  <div class="bill-item-value"><%= project.actionDate %></div>
                </div>
                <div class="bill-item">
                  <div class="bill-item-label">Bill Generated By:</div>
                  <div class="bill-item-value"><%= project.billGeneratedBy ? project.billGeneratedBy.name : 'N/A' %></div>
                </div>
                <div class="bill-item">
                  <div class="bill-item-label">Generation Date:</div>
                  <div class="bill-item-value"><%= project.billGeneratedAt %></div>
                </div>
                <div class="bill-item">
                  <div class="bill-item-label">Bill ID:</div>
                  <div class="bill-item-value">#<%= project._id.toString().slice(-8).toUpperCase() %></div>
                </div>
              </div>
            </div>

            <div class="bill-actions">
              <% if (project.billExists) { %>
                <button class="btn btn-print" onclick="window.print()">
                  <i class="fas fa-print"></i> Print Bill
                </button>
              <% } else { %>
                <div class="alert alert-danger">
                  <i class="fas fa-exclamation-triangle"></i> 
                  The bill file could not be located on the server. Please contact the administrator.
                </div>
                <button class="btn btn-warning" onclick="window.location.href='/officials-bill'">
                  <i class="fas fa-arrow-left"></i> Back to Bills
                </button>
              <% } %>
            </div>
          </div>
        </div>
      </div>
    </main>
  </div>

  <!-- Toast -->
  <div id="toast" role="alert" aria-live="assertive"></div>

  <!-- Scripts -->
  <script src="/socket.io/socket.io.js" defer></script>
  <script src="/js/socket-notification.js" defer></script>
  <script>
    document.addEventListener('DOMContentLoaded', function() {
      // Mobile sidebar toggle
      const sidebarToggle = document.getElementById('sidebarToggle');
      const sidebar = document.getElementById('sidebar');
      
      if (sidebarToggle && sidebar) {
        sidebarToggle.addEventListener('click', function() {
          sidebar.classList.toggle('active');
        });
      }
      
      // Profile dropdown functionality
      const profileIcon = document.querySelector('.profile-icon');
      const dropdownMenu = document.querySelector('.dropdown-menu');
      
      if (profileIcon && dropdownMenu) {
        profileIcon.addEventListener('click', function() {
          dropdownMenu.classList.toggle('show');
        });
        
        // Close dropdown when clicking outside
        document.addEventListener('click', function(event) {
          if (!profileIcon.contains(event.target) && !dropdownMenu.contains(event.target)) {
            dropdownMenu.classList.remove('show');
          }
        });
      }
    });
  </script>
</body>
</html> 