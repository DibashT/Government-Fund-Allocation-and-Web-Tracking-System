<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard</title>
    <script src="https://kit.fontawesome.com/a076d05399.js" crossorigin="anonymous"></script>
    <link rel="stylesheet" href="/request.css">
</head>
<body>
    <div class="wrapper">
        <!-- Sidebar -->
        <div class="sidebar">
            <h2>
                <img src="image/LOGO.png" class="logo" alt="Logo">
            </h2>
            <ul>
                <li><a href="/admin-dashboard">Home</a></li>
                <li><a href="/request">Request</a></li>
                <li><a href="/users">Users</a></li>
                <li><a href="/history">History</a></li>
                <li><a href="/logout">Logout</a></li>
            </ul>
        </div>

        <!-- Main Content -->
        <div class="main-content">
            <div class="content">
                <h1>Project Requests</h1>
                <table>
                    <thead>
                        <tr>
                            <th>S.N</th>
                            <th>Project Name</th>
                            <th>Department</th>
                            <th>Allocated Fund</th>
                            <th>Start Date</th>
                            <th>Deadline</th>
                            <th>Details</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (projects.length > 0) { %>
                            <% projects.forEach((project, index) => { %>
                                <tr>
                                    <td><%= index + 1 %></td>
                                    <td><%= project.projectName %></td>
                                    <td><%= project.department %></td>
                                    <td><%= project.allocatedFund %></td>
                                    <td><%= new Date(project.startDate).toLocaleDateString() %></td>
                                    <td><%= new Date(project.projectDeadline).toLocaleDateString() %></td>
                                    <td>
                                      <a href="/project-details/<%= project._id %>" class="view-btn">View</a>
                                    </td>
                                  
                                    <td class="actions">
                                        <!-- Approve Button -->
                                        <form action="/approve-project/<%= project._id %>" method="POST" style="display:inline;">
                                            <button class="approve">Approve</button>
                                        </form>

                                        <!-- Reject Button -->
                                        <form action="/reject-project/<%= project._id %>" method="POST" style="display:inline;">
                                            <button class="reject" onclick="return confirm('Are you sure you want to reject this project?');">Reject</button>
                                        </form>
                                    </td>
                                </tr>
                            <% }); %>
                        <% } else { %>
                            <tr>
                                <td colspan="8">No projects found.</td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

</body>
</html>
