<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Verify Code - Government Fund Allocation System</title>
    <link rel="stylesheet" href="/css/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.3/css/all.min.css">
    <style>
        body {
            background-color: #f5f5f5;
            font-family: 'Poppins', sans-serif;
            color: #333;
        }
        .container {
            max-width: 450px;
            margin: 50px auto;
            padding: 30px;
            background: #fff;
            border-radius: 10px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
            text-align: center;
        }
        h2 {
            color: #333;
            margin-bottom: 20px;
            font-weight: 600;
        }
        .form-group {
            margin-bottom: 25px;
        }
        label {
            display: block;
            margin-bottom: 8px;
            font-weight: 500;
            color: #555;
            text-align: left;
        }
        input {
            width: 100%;
            padding: 12px;
            border: 1px solid #ddd;
            border-radius: 6px;
            box-sizing: border-box;
            transition: border-color 0.3s ease;
            font-size: 16px;
        }
        input:focus {
            border-color: #4CAF50;
            outline: none;
            box-shadow: 0 0 0 2px rgba(76, 175, 80, 0.2);
        }
        button {
            width: 100%;
            padding: 14px;
            background: #4CAF50;
            color: white;
            border: none;
            border-radius: 6px;
            cursor: pointer;
            font-size: 16px;
            font-weight: 500;
            transition: background 0.3s ease;
            margin-top: 10px;
        }
        button:hover {
            background: #45a049;
        }
        button:disabled {
            background: #a5d6a7;
            cursor: not-allowed;
        }
        .message {
            margin-bottom: 20px;
            padding: 12px;
            border-radius: 6px;
            font-size: 14px;
        }
        .error-message {
            background-color: #ffebee;
            color: #c62828;
            border-left: 4px solid #f44336;
        }
        .success-message {
            background-color: #e8f5e9;
            color: #2e7d32;
            border-left: 4px solid #4CAF50;
        }
        .resend-container {
            margin-top: 25px;
            padding-top: 15px;
            border-top: 1px solid #eee;
        }
        .resend-link {
            color: #2196F3;
            text-decoration: none;
            font-size: 14px;
            display: inline-block;
            transition: color 0.3s ease;
        }
        .resend-link:hover {
            color: #0d47a1;
            text-decoration: underline;
        }
        .email-display {
            margin-bottom: 25px;
            color: #666;
            font-size: 15px;
            background-color: #f9f9f9;
            padding: 12px;
            border-radius: 6px;
        }
        .email-highlight {
            color: #2196F3;
            font-weight: 500;
        }
        .otp-container {
            display: flex;
            justify-content: space-between;
            margin-bottom: 20px;
        }
        .otp-input-container {
            position: relative;
        }
        .otp-digit {
            width: 50px;
            height: 60px;
            font-size: 24px;
            text-align: center;
            margin: 0 5px;
            border: 2px solid #ddd;
            border-radius: 8px;
            background-color: #fff;
        }
        .otp-digit:focus {
            border-color: #4CAF50;
            box-shadow: 0 0 0 2px rgba(76, 175, 80, 0.2);
        }
        .timer {
            margin-top: 15px;
            font-size: 14px;
            color: #666;
        }
        .hidden-input {
            position: absolute;
            opacity: 0;
            pointer-events: none;
        }
        .back-link {
            display: inline-block;
            margin-top: 15px;
            color: #666;
            text-decoration: none;
            font-size: 14px;
        }
        .back-link i {
            margin-right: 5px;
        }
        .back-link:hover {
            color: #333;
        }
        .verification-icon {
            font-size: 48px;
            color: #4CAF50;
            margin-bottom: 15px;
        }
    </style>
</head>
<body>
    <div class="container">
        <i class="fas fa-shield-alt verification-icon"></i>
        <h2>Verify Your Email</h2>
        
        <% if (locals.message) { %>
            <div class="message <%= typeof message === 'object' ? (message.type === 'error' ? 'error-message' : 'success-message') : 'info-message' %>">
                <%= typeof message === 'object' ? message.text : message %>
            </div>
        <% } %>

        <div class="email-display">
            We've sent a 6-digit verification code to<br>
            <span class="email-highlight"><%= email %></span>
        </div>
        
        <form id="verifyForm" action="/verify-otp" method="POST">
            <input type="hidden" name="email" value="<%= email %>">
            <input type="hidden" id="otpValue" name="otp">
            
            <div class="form-group">
                <label for="otp1">Enter verification code:</label>
                <div class="otp-container">
                    <input type="text" class="otp-digit" id="otp1" maxlength="1" autocomplete="off">
                    <input type="text" class="otp-digit" id="otp2" maxlength="1" autocomplete="off">
                    <input type="text" class="otp-digit" id="otp3" maxlength="1" autocomplete="off">
                    <input type="text" class="otp-digit" id="otp4" maxlength="1" autocomplete="off">
                    <input type="text" class="otp-digit" id="otp5" maxlength="1" autocomplete="off">
                    <input type="text" class="otp-digit" id="otp6" maxlength="1" autocomplete="off">
                </div>
            </div>
            
            <div class="timer" id="timer">Code expires in: <span id="countdown">10:00</span></div>
            
            <button type="submit" id="verifyButton" disabled>Verify Code</button>
        </form>
        
        <div class="resend-container">
            <span id="resendText">Didn't receive the code?</span>
            <a href="#" id="resendLink" class="resend-link" style="display:none;">
                Resend verification code
            </a>
            <span id="resendTimer" class="resend-link">Resend code in <span id="resendCountdown">60</span>s</span>
        </div>
        
        <a href="/signup" class="back-link">
            <i class="fas fa-arrow-left"></i> Back to signup
        </a>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const form = document.getElementById('verifyForm');
            const otpDigits = document.querySelectorAll('.otp-digit');
            const otpValue = document.getElementById('otpValue');
            const verifyButton = document.getElementById('verifyButton');
            const resendLink = document.getElementById('resendLink');
            const resendTimer = document.getElementById('resendTimer');
            const resendCountdown = document.getElementById('resendCountdown');
            const countdown = document.getElementById('countdown');
            
            // Focus first input on load
            otpDigits[0].focus();
            
            // Set up OTP input behavior
            otpDigits.forEach((digit, index) => {
                // Only allow numbers
                digit.addEventListener('input', function(e) {
                    this.value = this.value.replace(/[^0-9]/g, '');
                    
                    // Auto advance to next input
                    if (this.value && index < otpDigits.length - 1) {
                        otpDigits[index + 1].focus();
                    }
                    
                    updateOtpValue();
                });
                
                // Handle backspace
                digit.addEventListener('keydown', function(e) {
                    if (e.key === 'Backspace' && !this.value && index > 0) {
                        otpDigits[index - 1].focus();
                    }
                });
                
                // Handle paste event for the entire OTP
                digit.addEventListener('paste', function(e) {
                    e.preventDefault();
                    const pasteData = e.clipboardData.getData('text').replace(/[^0-9]/g, '').substring(0, 6);
                    
                    if (pasteData) {
                        // Distribute the pasted digits
                        for (let i = 0; i < pasteData.length && i < otpDigits.length; i++) {
                            otpDigits[i].value = pasteData[i];
                        }
                        
                        // Focus on the appropriate field
                        if (pasteData.length < otpDigits.length) {
                            otpDigits[pasteData.length].focus();
                        } else {
                            otpDigits[otpDigits.length - 1].focus();
                        }
                        
                        updateOtpValue();
                    }
                });
            });
            
            // Update hidden input with combined OTP value
            function updateOtpValue() {
                let otp = '';
                let isComplete = true;
                
                otpDigits.forEach(digit => {
                    otp += digit.value;
                    if (!digit.value) isComplete = false;
                });
                
                otpValue.value = otp;
                verifyButton.disabled = !isComplete;
            }
            
            // Handle form submission
            form.addEventListener('submit', function(e) {
                if (otpValue.value.length !== 6) {
                    e.preventDefault();
                    alert('Please enter all 6 digits of the verification code');
                } else {
                    verifyButton.disabled = true;
                    verifyButton.textContent = 'Verifying...';
                }
            });
            
            // Countdown timer for code expiration (10 minutes)
            let timeLeft = 10 * 60; // 10 minutes in seconds
            const countdownTimer = setInterval(function() {
                const minutes = Math.floor(timeLeft / 60);
                const seconds = timeLeft % 60;
                countdown.textContent = `${minutes}:${seconds < 10 ? '0' : ''}${seconds}`;
                
                if (timeLeft <= 0) {
                    clearInterval(countdownTimer);
                    countdown.textContent = 'Expired';
                    verifyButton.disabled = true;
                }
                
                timeLeft--;
            }, 1000);
            
            // Countdown for resend button (60 seconds)
            let resendTime = 60;
            const resendCountdownTimer = setInterval(function() {
                resendCountdown.textContent = resendTime;
                
                if (resendTime <= 0) {
                    clearInterval(resendCountdownTimer);
                    resendTimer.style.display = 'none';
                    resendLink.style.display = 'inline';
                }
                
                resendTime--;
            }, 1000);
            
            // Handle resend link
            resendLink.addEventListener('click', function(e) {
                e.preventDefault();
                window.location.href = `/resend-otp?email=${encodeURIComponent('<%= email %>')}`;
            });
        });
    </script>
</body>
</html>