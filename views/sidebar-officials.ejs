<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title> <!-- Dynamic title -->
    <script src="https://kit.fontawesome.com/a076d05399.js" crossorigin="anonymous"></script>
    <style>
        /* General Styles */
        body {
            margin: 0;
            font-family: Arial, sans-serif;
            display: flex;
            flex-direction: column;
            height: 100vh;
        }

        /* Wrapper */
        .wrapper {
            display: flex;
            height: 100%;
        }

        /* Sidebar Styles */
        .sidebar {
            width: 250px;
            background-color: #2c3e50;
            color: white;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            padding: 20px 0;
        }

        .sidebar h2 {
            text-align: center;
        }

        .sidebar .logo {
            width: 120px;
            margin-bottom: 20px;
        }

        .sidebar ul {
            list-style: none;
            padding: 0;
        }

        .sidebar ul li {
            margin: 10px 0;
        }

        .sidebar ul li a {
            color: white;
            text-decoration: none;
            padding: 10px 20px;
            display: block;
        }

        .sidebar ul li a:hover {
            background-color: #1abc9c;
            border-radius: 4px;
        }

        .social_media {
            margin-top: auto;
            text-align: center;
        }

        /* Main Content Styles */
        .main_content {
            flex: 1;
            display: flex;
            flex-direction: column;
        }

        .main_content .header {
            background-color: #ecf0f1;
            padding: 10px 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .content {
            flex: 1;
            padding: 20px;
            background-color: #f9fafc;
        }
    </style>
</head>
<body>
    <div class="wrapper">
        <!-- Sidebar -->
        <div class="sidebar">
            <h2><img src="image/LOGO.png" class="logo" alt="Logo"></h2>
            <ul>
                <li><a href="/home">Home</a></li>
                <li><a href="/project-form">Project</a></li>
                <li><a href="/notification">Notification</a></li>
                <li><a href="/logout">Logout</a></li>
            </ul>
            <div class="social_media">
                <p>© 2024 Company Name</p>
            </div>
        </div>

        <!-- Main Content -->
        <div class="main_content">
            <div class="content">
                <!-- Dynamic content will be injected here -->
                <%- body %> <!-- This is where dynamic content will be inserted -->
            </div>
        </div>
    </div>
</body>
</html>
