<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard</title>
    <script src="https://kit.fontawesome.com/a076d05399.js" crossorigin="anonymous"></script>
    <style>
        /* General Styles */
        body {
            margin: 0;
            font-family: Arial, sans-serif;
            display: flex;
            flex-direction: column;
            height: 100vh;
        }

        /* Wrapper */
        .wrapper {
            display: flex;
            height: 100%;
        }

        /* Sidebar Styles */
        .sidebar {
            width: 250px;
            background-color: #2c3e50;
            color: white;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            padding: 20px 0;
        }

        .sidebar h2 {
            text-align: center;
        }

        .sidebar .logo {
            width: 120px;
            margin-bottom: 20px;
        }

        .sidebar ul {
            list-style: none;
            padding: 0;
        }

        .sidebar ul li {
            margin: 10px 0;
        }

        .sidebar ul li a {
            color: white;
            text-decoration: none;
            padding: 10px 20px;
            display: block;
        }

        .sidebar ul li a:hover {
            background-color: #1abc9c;
            border-radius: 4px;
        }

        .social_media {
            margin-top: auto;
            text-align: center;
        }

        /* Main Content Styles */
        .main_content {
            flex: 1;
            display: flex;
            flex-direction: column;
        }

        .main_content .header {
            background-color: #ecf0f1;
            padding: 10px 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .header .notification button,
        .header .profile button,
        .header .log-out {
            background: none;
            border: none;
            cursor: pointer;
            font-size: 1rem;
        }

        .header .notification i,
        .header .profile i {
            font-size: 1.2rem;
            margin-right: 5px;
        }

        .header .profile span {
            margin-left: 5px;
        }

        .header .log-out {
            color: #e74c3c;
        }

        .content {
            flex: 1;
            padding: 20px;
            background-color: #f9fafc;
        }
    </style>
</head>
<body>
    <div class="wrapper">
        <!-- Sidebar -->
        <div class="sidebar">
            <h2>
                <img src="image/LOGO.png" class="logo" alt="Logo">
            </h2>
            <ul>
                <li class="home"><a href="#" class="nav-item" onclick="navigateToPage('home.html')">Home</a></li>
                <li class="request"><a href="#" class="nav-item" onclick="navigateToPage('request.html')">Request</a></li>
                <li class="history"><a href="#" class="nav-item" onclick="navigateToPage('history.html')">History</a></li>
                <li class="notification"><a href="#" class="nav-item" onclick="navigateToPage('notification.html')">Notification</a></li>
                <li class="logout"><a href="#" class="nav-item" onclick="confirmLogout()">Logout</a></li>
            </ul>
            <div class="social_media">
                <p>© 2024 Company Name</p>
            </div>
        </div>

        <!-- Main Content -->
        <div class="main_content">
            <

            <div class="content">
                <h1>Welcome to the Minister Dashboard!</h1>
                <p>Use the sidebar to navigate between different sections.</p>
            </div>
        </div>
    </div>

</body>
</html>
