<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <meta name="description" content="Project bills list for government officials">
  <title>Project Bills | Dashboard</title>
  
  <!-- Preconnect -->
  <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="preconnect" href="https://cdnjs.cloudflare.com" crossorigin>
  
  <!-- Styles -->
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"/>
  <link rel="stylesheet" href="/officials-bill-list.css"/>
  <script src="/socket.io/socket.io.js" defer></script>
</head>

<body>
  <div class="wrapper">
    <!-- Mobile Toggle -->
    <div class="mobile-toggle" id="sidebarToggle">
      <i class="fas fa-bars"></i>
    </div>
    
    <!-- Sidebar -->
    <nav class="sidebar" id="sidebar">
      <h2>
        <img src="/images/logo.png" class="logo" alt="Logo">
      </h2>
      <ul>
        <li><a href="/officials-dashboard"><i class="fas fa-home"></i> Home</a></li>
        <li><a href="/officials-project"><i class="fas fa-tasks"></i> Project</a></li>
        <li><a href="/officials-project-progress"><i class="fas fa-chart-line"></i> Project Progress</a></li>
        <li><a href="/officials-notification"><i class="fas fa-bell"></i> Notification</a></li>
        <li><a href="/officials-bill" class="active"><i class="fas fa-file-invoice-dollar"></i> Bill</a></li>
      </ul>
    </nav>

    <div class="main-content">
      <div class="top-header">
        <h1>Project Bills</h1>
        <div class="profile-menu">
          <i class="fas fa-user-circle profile-icon" aria-label="User menu" title="<%= user.name %>"></i>
          <div class="dropdown-menu">
              <a href="/officials-profile"><i class="fas fa-user"></i> <%= user.name %></a>
              <a href="#" onclick="logout()"><i class="fas fa-sign-out-alt"></i> Logout</a>
          </div>
       </div>
      </div>

      <div class="content">
        <div class="stat-section">
          <div class="section-header"><i class="fas fa-file-invoice-dollar"></i> Project Bills</div>
          <div class="bills-container">
            <% if (projects && projects.length > 0) { %>
              <table>
                <thead>
                  <tr>
                    <th>S.N</th>
                    <th>Project Name</th>
                    <th>Department</th>
                    <th>Allocated Fund</th>
                    <th>Generated By</th>
                    <th>Generated On</th>
                    <th>Actions</th>
                  </tr>
                </thead>
                <tbody>
                  <% projects.forEach((project, index) => { %>
                    <tr>
                      <td><%= index + 1 %></td>
                      <td><%= project.projectName %></td>
                      <td><%= project.department %></td>
                      <td>Rs.<%= project.allocatedFund.toLocaleString() %></td>
                      <td><%= project.billGeneratedBy %></td>
                      <td><%= project.billGeneratedAt %></td>
                      <td class="action-buttons">
                        <a href="/officials-bill/<%= project._id %>" class="btn btn-view" aria-label="View bill details">
                          <i class="fas fa-eye"></i> View
                        </a>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            <% } else { %>
              <div class="empty-state">
                <i class="fas fa-file-invoice"></i>
                <h3>No Bills Available</h3>
                <p>There are no bills generated yet. Bills will appear here once they're generated by ministers.</p>
                <a href="/request-bill" class="btn btn-primary">Request a Bill</a>
              </div>
            <% } %>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Toast -->
  <div id="toast" role="alert" aria-live="assertive"></div>

  <!-- Scripts -->
  <script src="/js/socket-notification.js" defer></script>
  <script>
    document.addEventListener('DOMContentLoaded', function() {
      // Mobile sidebar toggle
      const sidebarToggle = document.getElementById('sidebarToggle');
      const sidebar = document.getElementById('sidebar');
      
      if (sidebarToggle && sidebar) {
        sidebarToggle.addEventListener('click', function() {
          sidebar.classList.toggle('active');
        });
      }
      
      // Profile dropdown functionality
      const profileIcon = document.querySelector('.profile-icon');
      const dropdownMenu = document.querySelector('.dropdown-menu');
      
      if (profileIcon && dropdownMenu) {
        profileIcon.addEventListener('click', function() {
          dropdownMenu.classList.toggle('show');
        });
        
        // Close dropdown when clicking outside
        document.addEventListener('click', function(event) {
          if (!profileIcon.contains(event.target) && !dropdownMenu.contains(event.target)) {
            dropdownMenu.classList.remove('show');
          }
        });
      }
      
      // Automatically check for new bills when notifications are received
      const socket = io();
      
      socket.on("new-notification", (notification) => {
        if (notification.status === "BillGenerated") {
          // Show a notification to the user that a new bill is available
          const toast = document.getElementById('toast');
          toast.textContent = notification.message;
          toast.className = 'success';
          
          setTimeout(() => {
            toast.className = '';
          }, 5000);
        }
      });
    });
  </script>
</body>
</html>
