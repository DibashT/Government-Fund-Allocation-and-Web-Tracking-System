<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Profile</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="stylesheet" href="/officials.css">
    <style>
        .profile-container {
            display: flex;
            justify-content: center;
            margin-top: 30px;
        }
        .profile-form {
            background: #f9f9f9;
            padding: 20px;
            border-radius: 8px;
            width: 60%;
        }
        .profile-form h2 {
            text-align: center;
            margin-bottom: 20px;
        }
        .profile-form label {
            font-weight: bold;
        }
        .profile-form input, .profile-form select {
            width: 100%;
            padding: 10px;
            margin: 10px 0;
            border: 1px solid #ccc;
            border-radius: 4px;
        }
        .profile-form button {
            background-color: #2c3e50;
            color: white;
            padding: 10px 20px;
            border: none;
            border-radius: 4px;
            cursor: pointer;
            width: 100%;
        }
        .profile-form button:hover {
            background-color: #34495e;
        }
        .profile-form .back-button {
            text-align: center;
            margin-top: 20px;
        }
        .profile-form .back-button a {
            color: #2c3e50;
            text-decoration: none;
            font-size: 16px;
        }
        .profile-form .back-button a:hover {
            text-decoration: underline;
        }
    </style>
</head>
<body>
    <div class="wrapper">
        <!-- Sidebar -->
        <div class="sidebar">
            <h2>
                <img src="/image/logo.png" class="logo" alt="Logo" style="width: 150px;">
            </h2>
            <ul>
                <li><a href="/officials-dashboard"><i class="fas fa-home"></i> Home</a></li>
                <li><a href="/officials-project"><i class="fas fa-tasks"></i> Project</a></li>
                <li><a href="/officials-project-progress"><i class="fas fa-chart-line"></i> Project Progress</a></li>
                <li><a href="/officials-notification"><i class="fas fa-bell"></i> Notification</a></li>
                <li><a href="/logout"><i class="fas fa-sign-out-alt"></i> Logout</a></li>
            </ul>
        </div>

        <!-- Main Content -->
        <div class="main-content">
            <div class="top-header">
                <h1>Profile</h1>
            </div>

            <div class="profile-container">
                <div class="profile-form">
                    <h2>Edit Profile</h2>
                    <form action="/profile/update" method="POST">
                        <label for="name">Name</label>
                        <input type="text" id="name" name="name" value="<%= user.name %>" required>

                        <label for="email">Email</label>
                        <input type="email" id="email" name="email" value="<%= user.email %>" required>

                        <label for="phone">Phone Number</label>
                        <input type="text" id="phone" name="phone" value="<%= user.phone %>" required>

                        <label for="role">Role</label>
                        <select id="role" name="role" disabled>
                            <option value="Minister" <%= user.role === 'Minister' ? 'selected' : '' %>>Minister</option>
                            <option value="Government Official" <%= user.role === 'Government Official' ? 'selected' : '' %>>Government Official</option>
                            <option value="Public" <%= user.role === 'Public' ? 'selected' : '' %>>Public</option>
                            <option value="Admin" <%= user.role === 'Admin' ? 'selected' : '' %>>Admin</option>
                        </select>

                        <button type="submit">Update Profile</button>
                    </form>
                    <div class="back-button">
                        <a href="/officials-dashboard">Back to Dashboard</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
